{
  "name": "resuxjs",
  "version": "0.2.23",
  "private": false,
  "description": "Experimental resumable web framework with Vue-like SFC routing and a custom SSR/runtime pipeline.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "resux",
    "resumable",
    "framework",
    "ssr",
    "vite",
    "vue",
    "routing"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MahmoudAbdalrhmanMohamed/resux.git"
  },
  "bugs": {
    "url": "https://github.com/MahmoudAbdalrhmanMohamed/resux/issues"
  },
  "homepage": "https://github.com/MahmoudAbdalrhmanMohamed/resux#readme",
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "bin": {
    "resuxjs": "dist/cli.js",
    "resux": "dist/cli.js",
    "create-resux": "dist/create.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "default": "./dist/node.js"
    },
    "./globals": {
      "types": "./dist/globals.d.ts",
      "import": "./dist/globals.js",
      "default": "./dist/globals.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js",
      "default": "./dist/runtime/index.js"
    },
    "./reactivity": {
      "types": "./dist/reactivity/index.d.ts",
      "import": "./dist/reactivity/index.js",
      "default": "./dist/reactivity/index.js"
    },
    "./compiler": {
      "types": "./dist/compiler/index.d.ts",
      "import": "./dist/compiler/index.js",
      "default": "./dist/compiler/index.js"
    },
    "./create": {
      "types": "./dist/create.d.ts",
      "import": "./dist/create.js",
      "default": "./dist/create.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "tsc -b",
    "build": "npm run typecheck",
    "test": "vitest run",
    "create:local": "npm run build && node dist/cli.js init",
    "pack:check": "npm run build && npm test && npm pack --dry-run"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/compiler-dom": "^3.5.22",
    "@vue/compiler-sfc": "^3.5.22",
    "h3": "^1.15.4",
    "nitropack": "^2.12.6",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "vue": "^3.5.33"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "happy-dom": "^20.0.10",
    "vitest": "^4.0.8"
  }
}
